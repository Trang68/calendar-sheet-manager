PORT=8080
NODE_ENV=production

# Service account JSON as a single-line JSON string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}

GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_TIMEZONE=Asia/Ho_Chi_Minh
SHEET_GID=0

# Optional: set to protect API calls from your web UI
APP_TOKEN=change-me
